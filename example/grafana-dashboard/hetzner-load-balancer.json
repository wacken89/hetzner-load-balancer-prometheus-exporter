          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "count(hetzner_load_balancer_service_state{hetzner_load_balancer_name=~\"$loadbalancer\"})",
          "legendFormat": "total",
          "refId": "B"

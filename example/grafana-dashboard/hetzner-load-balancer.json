        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "hetzner_load_balancer_open_connections{hetzner_load_balancer_name=~\"$loadbalancer\"}",

            "showPoints": "never",
            "spanNulls": true
          },
          "mappings": [],
          "unit": "Bps"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/.*out.*/" },
            "properties": [
              { "id": "custom.transform", "value": "negative-Y" }
